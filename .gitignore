.DS_Store
__pycache__/
*.py[cod]
.pytest_cache/
*.log
*_output.log
nohup*.out
*.pid

# Local data and generated artifacts
data/*.txt
!data/*readme*.txt
!data/dataset_TSMC2014_NYC.txt
!data/dataset_TSMC2014_TKY.txt

# Keep processed/ and runs/ ignored in general to avoid accidentally committing non-LFS files
# LFS-tracked files are force-added separately

# Virtual environments and local editor state
.venv/
venv/
.idea/
.vscode/

previous/

# LaTeX generated files
latex/*.aux
latex/*.bbl
latex/*.bcf
latex/*.blg
latex/*.fdb_latexmk
latex/*.fls
latex/*.log
latex/*.run.xml
latex/*.xdv
latex/*.synctex.gz

# Local debug / efficiency experiment artifacts
processed/debug*/
runs/debug*/
runs/*_local/
runs/nyc_optim*/
runs/nyc_p0_optim/
runs/nyc_small_candidate_reranker*/

# Python packaging/build metadata
*.egg-info/

# Local large experiment outputs. Keep reproducible baseline artifacts already
# tracked under runs/nyc_mvp/, but avoid accidentally adding ad-hoc checkpoints.
runs/nyc_4090*/
runs/*benchmark*/
